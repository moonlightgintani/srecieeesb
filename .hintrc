{
  "extends": [
    "development"
  ],
  "hints": {
    "axe/name-role-value": "off",
    "no-inline-styles": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "backdrop-filter",
          "border: 1px solid color-mix(in oklab, white 60%, transparent)",
          "border: 1px solid color-mix(in oklab, white 15%, transparent)"
        ]
      }
    ]
  }
}